{
  "name": "draftila",
  "version": "0.3.1",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "api:dev": "bun run --filter @draftila/api dev",
    "api:build": "bun run --filter @draftila/api build",
    "api:start": "bun run --filter @draftila/api start",
    "api:test": "bun run --filter @draftila/api test",
    "api:typecheck": "bun run --filter @draftila/api typecheck",
    "api:lint": "bun run --filter @draftila/api lint",
    "api:clean": "bun run --filter @draftila/api clean",
    "api:db:generate": "bun run --filter @draftila/api db:generate",
    "api:db:migrate": "bun run --filter @draftila/api db:migrate",
    "api:db:studio": "bun run --filter @draftila/api db:studio",
    "api:db:seed": "bun run --filter @draftila/api db:seed",
    "api:db:reset": "bun run --filter @draftila/api db:reset",
    "api:db:refresh": "bun run --filter @draftila/api db:refresh",
    "api:routes:list": "bun run --filter @draftila/api routes:list",
    "website:dev": "bun run --filter @draftila/website dev",
    "website:build": "bun run --filter @draftila/website build",
    "website:start": "bun run --filter @draftila/website start",
    "clean": "turbo clean && rm -rf node_modules",
    "checks": "bash scripts/checks.sh",
    "checks:fix": "bash scripts/checks.sh --fix"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "turbo": "^2.3.3"
  },
  "packageManager": "bun@1.1.38"
}
