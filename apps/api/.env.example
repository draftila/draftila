# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/draftila
DB_POOL_MAX=10

# Auth
BETTER_AUTH_SECRET=your-secret-key-change-this
BETTER_AUTH_URL=http://localhost:3001

# Frontend
FRONTEND_URL=http://localhost:5173

# Server
PORT=3001

# Trusted proxy IPs (comma-separated, or "*" to trust all proxies)
# When set, X-Forwarded-For/X-Real-IP headers from these IPs are trusted for rate limiting.
# When behind nginx in the same Docker container, use "*" or "127.0.0.1".
# When NOT behind a proxy, leave unset — Bun's TCP socket IP is used directly.
# TRUSTED_PROXY_IPS=*
