{
  "name": "@draftila/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "test": "bun test",
    "lint": "eslint .",
    "clean": "rm -rf dist .turbo",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/db/seed.ts",
    "db:reset": "bun run src/db/reset.ts",
    "db:refresh": "bun run db:reset && bun run db:migrate && bun run db:seed",
    "routes:list": "bun run src/routes-list.ts"
  },
  "dependencies": {
    "@draftila/shared": "workspace:*",
    "better-auth": "^1.1.14",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.14",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@draftila/eslint-config": "workspace:*",
    "@draftila/typescript-config": "workspace:*",
    "@types/bun": "^1.1.14",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.16.0",
    "typescript": "^5.7.2"
  }
}
