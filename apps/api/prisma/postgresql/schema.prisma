generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated/prisma/postgresql-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false) @map("email_verified")
  image         String?
  role          String?   @default("user")
  banned        Boolean   @default(false)
  banReason     String?   @map("ban_reason")
  banExpires    DateTime? @map("ban_expires")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  sessions      Session[]
  accounts      Account[]
  projects      Project[]
  memberships   ProjectMember[]
  apiKeys       ApiKey[]
  comments      Comment[]
  commentReads  CommentRead[]
  snapshots     Snapshot[]

  @@map("user")
}

model Session {
  id               String   @id
  expiresAt        DateTime @map("expires_at")
  token            String   @unique
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  ipAddress        String?  @map("ip_address")
  userAgent        String?  @map("user_agent")
  userId           String   @map("user_id")
  impersonatedBy   String?  @map("impersonated_by")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "session_user_id_idx")
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "account_user_id_idx")
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("verification")
}

model Project {
  id         String          @id
  name       String
  logo       String?
  isPersonal Boolean         @default(false) @map("is_personal")
  ownerId    String          @map("owner_id")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  owner      User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  drafts     Draft[]
  members    ProjectMember[]

  @@index([ownerId], map: "project_owner_id_idx")
  @@map("project")
}

model ProjectMember {
  id        String   @id
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  role      String   @default("viewer")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId], map: "project_member_project_user_idx")
  @@index([userId], map: "project_member_user_id_idx")
  @@map("project_member")
}

model ApiKey {
  id         String    @id
  name       String
  keyHash    String    @unique @map("key_hash")
  userId     String    @map("user_id")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "api_key_user_id_idx")
  @@map("api_key")
}

model Draft {
  id        String     @id
  name      String
  projectId String     @map("project_id")
  yjsState  Bytes?     @map("yjs_state")
  thumbnail String?
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comments  Comment[]
  snapshots Snapshot[]

  @@index([projectId], map: "draft_project_id_idx")
  @@map("draft")
}

model Snapshot {
  id        String   @id
  draftId   String   @map("draft_id")
  userId    String?  @map("user_id")
  name      String?
  yjsState  Bytes    @map("yjs_state")
  createdAt DateTime @default(now()) @map("created_at")
  draft     Draft    @relation(fields: [draftId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([draftId, createdAt(sort: Desc)], map: "snapshot_draft_created_idx")
  @@map("snapshot")
}

model Comment {
  id        String      @id
  draftId   String      @map("draft_id")
  pageId    String      @map("page_id")
  userId    String      @map("user_id")
  content   String
  parentId  String?     @map("parent_id")
  resolved  Boolean     @default(false)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  draft     Draft       @relation(fields: [draftId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Comment?    @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[]   @relation("CommentReplies")
  reads     CommentRead[]

  @@index([draftId], map: "comment_draft_id_idx")
  @@index([pageId], map: "comment_page_id_idx")
  @@index([parentId], map: "comment_parent_id_idx")
  @@index([userId], map: "comment_user_id_idx")
  @@map("comment")
}

model CommentRead {
  id        String   @id
  commentId String   @map("comment_id")
  userId    String   @map("user_id")
  readAt    DateTime @default(now()) @map("read_at")
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId], map: "comment_read_comment_user_idx")
  @@index([userId], map: "comment_read_user_id_idx")
  @@map("comment_read")
}
